{
  "name": "createdomblocks",
  "version": "2.0.0",
  "description": "Creating complex HTML blocks using JS.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "style.css",
    "README.md",
    "README-hu.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "webpack",
    "build:page": "webpack && node scripts/build-page.mjs",
    "dev": "webpack serve --open",
    "typecheck": "tsc --noEmit",
    "test": "node --test scripts/example-loader.test.mjs",
    "clean": "rm -rf dist dist-page"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exphoenee/createDOMBlocks.git"
  },
  "keywords": [
    "DOM",
    "dom manipulation",
    "typescript",
    "form elements",
    "ui components"
  ],
  "author": "VIKTOR, Bozzay",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/exphoenee/createDOMBlocks/issues"
  },
  "homepage": "https://github.com/exphoenee/createDOMBlocks#readme",
  "dependencies": {
    "domelemjs": "^2.0.1"
  },
  "devDependencies": {
    "@babel/parser": "^8.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  }
}
